[
    {kernel, [
        {logger_level, debug},
        {logger, [
            {handler, default, logger_std_h, #{
                formatter => {nova_jsonlogger, #{
                    map_depth => 3,
                    term_depth => 50
                }}
            }}
        ]}
    ]},
    {nova_auth, [
        {pbkdf2_iterations, 100000}
    ]},
    {nova, [
        {use_stacktrace, true},
        {environment, dev},
        {cowboy_configuration, #{
            port => 8082
        }},
        {dev_mode, true},
        {bootstrap_application, asobi},
        {json_lib, json}
    ]},
    {kura, [
        {repo, asobi_repo},
        {host, "localhost"},
        {port, 5432},
        {database, "asobi_dev"},
        {user, "postgres"},
        {password, "postgres"},
        {pool_size, 10}
    ]},
    {asobi, [
        {nova_apps, [nova_resilience]},
        {plugins, [
            {pre_request, nova_request_plugin, #{
                decode_json_body => true,
                parse_qs => true
            }},
            {pre_request, nova_correlation_plugin, #{}},
            {pre_request, nova_cors_plugin, #{
                allow_origins => <<"*">>
            }}
        ]},
        {game_modes, #{
            %% Map mode names to game behaviour modules
            %% ~"default" => my_game_module
        }},
        {matchmaker, #{
            tick_interval => 1000,
            max_wait_seconds => 60
        }},
        {session, #{
            token_ttl => 900,
            refresh_ttl => 2592000
        }}
    ]},
    {shigoto, [
        {pool, asobi_repo}
    ]},
    {nova_resilience, [
        {dependencies, [
            #{name => primary_db,
              type => database,
              adapter => kura,
              repo => asobi_repo,
              critical => true,
              breaker => #{failure_threshold => 5, wait_duration => 30000},
              bulkhead => #{max_concurrent => 25},
              shutdown_priority => 2}
        ]},
        {health_check_interval, 10000},
        {vm_checks, true},
        {gate_enabled, false},
        {health_prefix, ~""}
    ]},
    {pg, [{scope, [nova_scope, asobi_presence, asobi_chat]}]}
].
